<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wfback.mapper.WPSModelMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.wfback.pojo.WPSModel">
        <id column="mid" property="mid" />
        <result column="mname" property="mname" />
        <result column="mparam" property="mparam" />
        <result column="mdescribe" property="mdescribe" />
        <result column="muploadtime" property="muploadtime" />
        <result column="muploadlocation" property="muploadlocation" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        mid,mname,mparam,mdescribe,muploadtime,muploadlocation
    </sql>

</mapper>
